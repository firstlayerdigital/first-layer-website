---
interface Props {
	title: string;
	description: string;
	metrics: string[];
	link: string;
}

const { title, description, metrics, link } = Astro.props;
---

<div class="bg-[var(--bg-card)] border border-[var(--stroke)] rounded-lg p-6 hover:border-[var(--accent)]/40 transition-colors duration-200">
	<h3 class="text-lg font-semibold text-[var(--text-header)] mb-2">{title}</h3>
	<p class="text-[var(--text-body)] text-sm mb-4 leading-relaxed">{description}</p>
	<ul class="text-sm text-[var(--text-body)] mb-4 space-y-1">
		{metrics.map((metric) => (
			<li class="flex items-center gap-2">
				<span class="w-1.5 h-1.5 bg-[var(--accent)] rounded-full"></span>
				{metric}
			</li>
		))}
	</ul>
	<a href={link} class="text-sm font-medium text-[var(--accent)] hover:text-[var(--accent-hover)] transition-colors inline-flex items-center gap-1">
		View Project <span>&rarr;</span>
	</a>
</div>
