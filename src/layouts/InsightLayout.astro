---
import '../styles/global.css';
import GoogleTags from '../components/GoogleTags.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "First Layer Digital",
	description = "Pasadena, Maryland software studio building fast websites, custom online stores, and tools that cut the busywork. Real software for businesses that want to grow."
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="keywords" content="custom software development, web design Maryland, online store development, business automation, ecommerce development, Shopify development, marketing dashboards, small business software, Pasadena Maryland web design" />
		<meta name="viewport" content="width=device-width" />

		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-icon-180x180.png" />

		<meta name="generator" content={Astro.generator} />

		<meta property="og:type" content="article" />
		<meta property="og:url" content="https://firstlayer.digital" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="https://firstlayer.digital/logo.svg" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="https://firstlayer.digital/logo.svg" />

		<meta name="theme-color" content="#0891b2" />

		<title>{title}</title>

		<script is:inline>
			(function() {
				const getTheme = () => {
					if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) return localStorage.getItem('theme');
					if (typeof window !== 'undefined' && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) return 'dark';
					return 'light';
				};
				const theme = getTheme();
				if (theme === 'dark') { document.documentElement.classList.add('dark'); }
				else { document.documentElement.classList.remove('dark'); }
				document.documentElement.setAttribute('data-theme', theme);
			})();
		</script>

		<GoogleTags />
		<script defer src="https://umami.ahrlink.me/script.js" data-website-id="a190b69f-a2cd-422f-8b87-40e1c49d7c0b"></script>
		<script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "d9a6d370f7284634a0bcb7486d55264e"}'></script>
	</head>

	<body class="bg-[var(--bg-page)] bg-[radial-gradient(#06b6d440_1px,transparent_1px)] bg-[size:24px_24px] font-sans text-[var(--text-body)] flex flex-col min-h-screen">

		<nav class="bg-[var(--bg-page)] text-[var(--text-header)] border-b border-[var(--stroke)] sticky top-0 z-50" role="navigation">
			<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-3 sm:py-4 flex flex-col md:flex-row justify-between items-center">
				<a href="/" class="mb-3 md:mb-0 flex items-center hover:opacity-80 transition-opacity">
					<img src="/logo.svg" alt="First Layer Digital" class="h-16 sm:h-20 md:h-24 lg:h-28 xl:h-32 w-auto" />
				</a>
				<div class="flex items-center flex-wrap justify-center gap-1 sm:gap-2 text-sm sm:text-base">
					<a href="/" class="text-[var(--text-muted)] hover:text-[var(--text-header)] font-medium transition-colors px-3 py-2 rounded-md hover:bg-[var(--bg-muted)] min-h-[44px] flex items-center">Home</a>
					<a href="/services" class="text-[var(--text-muted)] hover:text-[var(--text-header)] font-medium transition-colors px-3 py-2 rounded-md hover:bg-[var(--bg-muted)] min-h-[44px] flex items-center">Services</a>
					<a href="/work" class="text-[var(--text-muted)] hover:text-[var(--text-header)] font-medium transition-colors px-3 py-2 rounded-md hover:bg-[var(--bg-muted)] min-h-[44px] flex items-center">Work</a>
					<a href="/blog" class="text-[var(--text-muted)] hover:text-[var(--text-header)] font-medium transition-colors px-3 py-2 rounded-md hover:bg-[var(--bg-muted)] min-h-[44px] flex items-center">Insights</a>
					<a href="/about" class="text-[var(--text-muted)] hover:text-[var(--text-header)] font-medium transition-colors px-3 py-2 rounded-md hover:bg-[var(--bg-muted)] min-h-[44px] flex items-center">About</a>
					<a href="/contact" class="bg-[var(--accent)] hover:bg-[var(--accent-hover)] text-white px-4 sm:px-5 py-2 sm:py-2.5 rounded-md font-medium text-sm sm:text-base transition-colors min-h-[44px] flex items-center justify-center ml-2">Contact</a>

					<button id="theme-toggle-insight" aria-label="Toggle theme" class="w-10 h-10 rounded-md bg-[var(--bg-muted)] hover:bg-[var(--bg-subtle)] border border-[var(--stroke)] flex items-center justify-center transition-colors ml-2">
						<svg class="absolute w-5 h-5 text-amber-500 transition-all duration-200 scale-0 dark:scale-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
						<svg class="absolute w-5 h-5 text-[var(--text-muted)] transition-all duration-200 scale-100 dark:scale-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
					</button>
				</div>
			</div>
		</nav>

		<script>
			function initInsightThemeToggle() {
				const btn = document.getElementById('theme-toggle-insight');
				const html = document.documentElement;
				if (!btn) return;
				const newBtn = btn.cloneNode(true);
				btn.parentNode?.replaceChild(newBtn, btn);
				newBtn.addEventListener('click', () => {
					html.classList.toggle('dark');
					const t = html.classList.contains('dark') ? 'dark' : 'light';
					localStorage.setItem('theme', t);
					html.setAttribute('data-theme', t);
				});
			}
			if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', initInsightThemeToggle); }
			else { initInsightThemeToggle(); }
			document.addEventListener('astro:page-load', initInsightThemeToggle);
			document.addEventListener('astro:after-swap', initInsightThemeToggle);
		</script>

		<slot />

		<footer class="bg-[var(--bg-page)] py-10 mt-auto border-t border-[var(--stroke)]" role="contentinfo">
			<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
					<div class="text-center md:text-left">
						<img src="/logo.svg" alt="First Layer Digital" class="h-20 sm:h-24 w-auto opacity-90 mx-auto md:mx-0 mb-3" />
						<p class="text-sm text-[var(--text-body)] leading-relaxed">Building the web of tomorrow, today.</p>
						<div class="flex justify-center md:justify-start items-center gap-4 mt-3">
							<a href="https://www.instagram.com/firstlayerdigital/" target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors" aria-label="Instagram">
								<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63z" clip-rule="evenodd"/></svg>
							</a>
							<a href="https://github.com/firstlayerdigital/first-layer-website" target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors" aria-label="GitHub">
								<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
							</a>
						</div>
					</div>
					<div class="text-center md:text-left">
						<h3 class="text-sm font-semibold text-[var(--text-header)] mb-3 uppercase tracking-wide">Navigation</h3>
						<nav class="flex flex-col gap-2">
							<a href="/" class="text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors text-sm">Home</a>
							<a href="/services" class="text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors text-sm">Services</a>
							<a href="/work" class="text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors text-sm">Work</a>
							<a href="/blog" class="text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors text-sm">Insights</a>
							<a href="/about" class="text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors text-sm">About</a>
							<a href="/contact" class="text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors text-sm">Contact</a>
						</nav>
						<div class="mt-3 pt-3 border-t border-[var(--stroke)] flex flex-col gap-1 text-xs">
							<a href="/privacy" class="text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors">Privacy Policy</a>
							<a href="/terms" class="text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors">Client Terms</a>
						</div>
					</div>
					<div class="text-center md:text-left">
						<h3 class="text-sm font-semibold text-[var(--text-header)] mb-3 uppercase tracking-wide">Contact</h3>
						<div class="space-y-2 text-sm">
							<div>
								<p class="text-xs text-[var(--text-muted)]">Email</p>
								<a href="mailto:hello@firstlayer.digital" class="text-[var(--text-body)] hover:text-[var(--accent)] transition-colors">hello@firstlayer.digital</a>
							</div>
							<div>
								<p class="text-xs text-[var(--text-muted)]">Address</p>
								<p class="text-[var(--text-body)]">4301 Mountain Road, Unit 202<br/>Pasadena, Maryland 21123</p>
							</div>
						</div>
					</div>
				</div>
				<div class="border-t border-[var(--stroke)] pt-6 text-center">
					<p class="text-xs text-[var(--text-muted)]">&copy; {new Date().getFullYear()} First Layer Digital LLC. All rights reserved.</p>
				</div>
			</div>
		</footer>

	</body>
</html>
