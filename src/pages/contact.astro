---
import Layout from '../layouts/Layout.astro';

// Make this page static so Netlify can detect the form at build time
export const prerender = true;
---

<Layout
	title="Contact Us | Get Started with FirstLayer Digital | Pasadena, Maryland"
	description="Contact FirstLayer Digital for custom software development, operational infrastructure, data dashboards, and private cloud solutions. Schedule a consultation in Pasadena, Maryland."
>
	<main role="main">
		<div class="max-w-xl mx-auto px-4 sm:px-6 py-16 sm:py-20">

			<div class="text-center mb-10">
				<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 leading-tight">
					Let's Work <span class="text-[var(--accent-cyan)] drop-shadow-[0_0_12px_rgba(34,211,238,0.3)]">Together</span>
				</h1>
				<p class="text-base sm:text-lg text-[var(--text-body)] max-w-md mx-auto leading-relaxed">
					Tell us about your project. We'll get back to you within 24 hours.
				</p>
			</div>

			<form
				name="contact"
				method="POST"
				data-netlify="true"
				netlify-honeypot="bot-field"
				action="/contact"
				data-netlify-redirect="/success"
				class="bg-[var(--bg-card)] border border-[var(--stroke)] rounded-lg p-6 sm:p-8"
			>
				<!-- Hidden fields for Netlify -->
				<input type="hidden" name="form-name" value="contact" />
				<input type="hidden" name="_to" value="/success" />
				<p class="hidden">
					<label>Don't fill this out if you're human: <input name="bot-field" /></label>
				</p>

				<!-- Name -->
				<div class="mb-5">
					<label for="name" class="block text-sm font-medium text-[var(--text-header)] mb-1.5">Name</label>
					<input
						type="text"
						id="name"
						name="name"
						required
						placeholder="Your full name"
						class="w-full px-4 py-3 rounded-md border border-[var(--stroke)] focus:border-[var(--accent)] focus:ring-2 focus:ring-[var(--accent)]/20 outline-none transition-colors text-base bg-[var(--bg-page)] text-[var(--text-header)] placeholder:text-[var(--text-light)]"
					/>
				</div>

				<!-- Email -->
				<div class="mb-5">
					<label for="email" class="block text-sm font-medium text-[var(--text-header)] mb-1.5">Email</label>
					<input
						type="email"
						id="email"
						name="email"
						required
						placeholder="your.email@example.com"
						class="w-full px-4 py-3 rounded-md border border-[var(--stroke)] focus:border-[var(--accent)] focus:ring-2 focus:ring-[var(--accent)]/20 outline-none transition-colors text-base bg-[var(--bg-page)] text-[var(--text-header)] placeholder:text-[var(--text-light)]"
					/>
				</div>

				<!-- Message -->
				<div class="mb-6">
					<label for="message" class="block text-sm font-medium text-[var(--text-header)] mb-1.5">Project Details</label>
					<textarea
						id="message"
						name="message"
						rows="5"
						required
						placeholder="Tell us about your project, goals, and timeline..."
						class="w-full px-4 py-3 rounded-md border border-[var(--stroke)] focus:border-[var(--accent)] focus:ring-2 focus:ring-[var(--accent)]/20 outline-none transition-colors text-base resize-y bg-[var(--bg-page)] text-[var(--text-header)] placeholder:text-[var(--text-light)] min-h-[120px] leading-relaxed"
					></textarea>
				</div>

				<!-- Submit -->
				<button
					type="submit"
					class="w-full bg-[var(--accent)] text-white font-medium py-3 rounded-md hover:bg-[var(--accent-hover)] transition-colors duration-200 text-base min-h-[48px]"
				>
					Send Message
				</button>
			</form>
		</div>
	</main>

	<script>
		document.querySelector('form[name="contact"]')?.addEventListener('submit', async (e) => {
			e.preventDefault();
			const form = e.currentTarget as HTMLFormElement;
			const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
			const originalText = submitBtn?.textContent ?? '';

			if (submitBtn) {
				submitBtn.disabled = true;
				submitBtn.textContent = 'Sending\u2026';
			}

			try {
				const formData = new FormData(form);
				const body = new URLSearchParams();
				formData.forEach((value, key) => body.append(key, String(value)));

				const response = await fetch(form.action, {
					method: 'POST',
					body,
					headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
				});

				if (response.ok) {
					try { sessionStorage.setItem('fl_form_submitted', '1'); } catch (e) {}
					window.location.href = '/success';
					return;
				}
			} catch {
				form.submit();
				return;
			}

			if (submitBtn) {
				submitBtn.disabled = false;
				submitBtn.textContent = originalText;
			}
		});
	</script>
</Layout>
