---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

interface Project {
	id: string;
	title: string;
	tagline: string;
	url?: string;
	image: string;
	imageAlt: string;
	accent: 'cyan' | 'emerald' | 'violet';
	description: string;
	features: string[];
	stats: { label: string; value: string }[];
}

const projects: Project[] = [
	{
		id: 'p1-packaging',
		title: 'P1 Packaging',
		tagline: 'Custom Online Store & Wholesale Portal',
		url: 'https://p1packaging.com',
		image: '/images/p1-packaging-showcase.png',
		imageAlt: 'P1 Packaging online store with wholesale portal',
		accent: 'emerald',
		description: 'A Maryland-based packaging supplier with a retail storefront and a separate wholesale business. They needed both to feel native, with ad tracking that actually works and shipping hooked straight in.',
		features: [
			'Custom wholesale portal with a quick-order page for repeat buyers',
			'Accurate ad conversion tracking through to the final sale',
			'Shipping costs and labels wired into the order flow',
			'Private analytics so the numbers stay in-house',
			'Hidden arcade easter egg, because why not',
		],
		stats: [
			{ label: 'Google Ads ROAS', value: '10x' },
			{ label: 'Channels', value: 'Retail + Wholesale' },
			{ label: 'Ad Tracking', value: 'End-to-End' },
			{ label: 'Support', value: 'Ongoing' },
		],
	},
	{
		id: 'vantagedash',
		title: 'VantageDash',
		tagline: 'Competitive Intelligence Platform',
		url: 'https://vantagedash.io',
		image: '/images/vantagedash-showcase.png',
		imageAlt: 'VantageDash homepage showing competitor price tracking',
		accent: 'cyan',
		description: 'E-commerce brands live and die by pricing. VantageDash tracks every competitor you have, matches their products to yours, and pings you the moment something changes.',
		features: [
			'Auto-detects 8+ online store platforms from a single URL',
			'AI product matching handles different names and bundle sizes',
			'Real-time alerts via Slack or email when prices move',
			'Price trend charts and competitor heatmaps',
			'Exports for team sharing and reporting',
		],
		stats: [
			{ label: 'Products Tracked', value: '47,000+' },
			{ label: 'Match Accuracy', value: '90%+' },
			{ label: 'Platforms Supported', value: '8+' },
			{ label: 'Setup Time', value: '< 5 min' },
		],
	},
	{
		id: 'first-layer-digital',
		title: 'First Layer Digital',
		tagline: 'The Site You\'re On Right Now',
		url: '/',
		image: '/images/work-fld.png',
		imageAlt: 'First Layer Digital marketing site',
		accent: 'violet',
		description: 'Our own marketing site. Built with the same tools we use for clients: fast, dark by default, and engineered to rank. A Lighthouse score of 98 and pages that load before you blink.',
		features: [
			'Zero JavaScript shipped on most pages',
			'Perfect Core Web Vitals across the board',
			'Dark theme with cyan accents and visual rhythm',
			'Automated deploys on every push to main',
			'Private analytics, no cookie banners needed',
		],
		stats: [
			{ label: 'Lighthouse', value: '98' },
			{ label: 'Load Time', value: '< 0.5s' },
			{ label: 'Core Web Vitals', value: 'All Green' },
			{ label: 'JS Shipped', value: '~0 KB' },
		],
	},
];

const accentMap = {
	cyan: {
		eyebrow: 'text-cyan-400',
		border: 'border-cyan-500/30',
		glow: 'shadow-cyan-500/20',
		bar: 'bg-cyan-500',
		hover: 'hover:text-cyan-300',
	},
	emerald: {
		eyebrow: 'text-emerald-400',
		border: 'border-emerald-500/30',
		glow: 'shadow-emerald-500/20',
		bar: 'bg-emerald-500',
		hover: 'hover:text-emerald-300',
	},
	violet: {
		eyebrow: 'text-violet-400',
		border: 'border-violet-500/30',
		glow: 'shadow-violet-500/20',
		bar: 'bg-violet-500',
		hover: 'hover:text-violet-300',
	},
};

const caseStudies = (await getCollection('work')).sort((a, b) =>
	b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout
	title="Our Work | Real Projects, Real Outcomes | First Layer Digital"
	description="A look at what we've actually shipped. Custom software, online stores, and fast marketing sites built for real businesses."
>
	<main class="relative overflow-hidden" role="main">

		<!-- ============================================
		     HERO
		     ============================================ -->
		<section class="relative pt-12 sm:pt-16 md:pt-24 pb-12 sm:pb-16 px-4 sm:px-6" aria-label="Work hero">
			<div class="absolute inset-0 -z-10 pointer-events-none">
				<div class="absolute top-0 right-1/4 w-96 h-96 bg-[var(--accent-cyan)]/10 rounded-full blur-3xl"></div>
				<div class="absolute bottom-0 left-1/4 w-72 h-72 bg-[var(--accent-cyan)]/8 rounded-full blur-3xl"></div>
			</div>

			<div class="max-w-4xl mx-auto text-center">
				<div class="inline-flex items-center gap-2 bg-[var(--bg-card)] border border-[var(--stroke)] rounded-full px-4 py-1.5 mb-6 text-xs font-mono uppercase tracking-wider text-[var(--text-muted)]">
					<span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
					Real Projects
				</div>

				<h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-6 leading-[1.05]">
					Real Work.<br />
					<span style="color: #3b82f6;">Real Outcomes.</span>
				</h1>

				<p class="text-lg sm:text-xl text-[var(--text-body)] max-w-2xl mx-auto leading-relaxed">
					A look at what we've actually shipped. Not mockups, not template demos. The live stuff that keeps running every day.
				</p>
			</div>
		</section>

		<!-- ============================================
		     PROJECTS (alternating showcase)
		     ============================================ -->
		<section class="relative py-12 sm:py-16 md:py-20 border-t border-[var(--stroke)]" aria-label="Projects">
			<div class="absolute inset-0 -z-10 pointer-events-none dot-grid-subtle opacity-40"></div>

			<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16 sm:space-y-20">
				{projects.map((project, idx) => {
					const accent = accentMap[project.accent];
					const reverse = idx % 2 === 1;
					const isExternal = project.url?.startsWith('http');
					return (
						<article class="grid md:grid-cols-2 gap-8 sm:gap-12 items-center">
							<!-- Image -->
							<div class={`relative ${reverse ? 'md:order-2' : ''}`}>
								{project.accent === 'cyan' && <div class="absolute -top-6 -right-6 w-12 h-12 rounded-lg bg-cyan-500/20 rotate-12 float-shape hidden md:block"></div>}
								{project.accent === 'emerald' && <div class="absolute -bottom-4 -left-4 w-8 h-8 rounded-full bg-emerald-400/30 float-shape float-shape-slow hidden md:block"></div>}
								{project.accent === 'violet' && <div class="absolute top-1/2 -right-8 w-4 h-4 rounded-full bg-violet-400/50 float-shape hidden md:block"></div>}
								<div class="browser-frame">
									<img src={project.image} alt={project.imageAlt} loading="lazy" width="1280" height="800" />
								</div>
							</div>

							<!-- Text -->
							<div class={reverse ? 'md:order-1' : ''}>
								<span class={`inline-block text-xs font-mono uppercase tracking-[0.2em] ${accent.eyebrow} mb-3`}>
									{project.tagline}
								</span>
								<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4 leading-tight">
									{project.title}
								</h2>
								<p class="text-base sm:text-lg text-[var(--text-body)] mb-6 leading-relaxed">
									{project.description}
								</p>

								<ul class="space-y-2.5 mb-6">
									{project.features.map((feature) => (
										<li class="flex items-start gap-2.5 text-sm sm:text-base text-[var(--text-body)]">
											<span class={`${accent.eyebrow} mt-1 flex-shrink-0`}>&rarr;</span>
											<span>{feature}</span>
										</li>
									))}
								</ul>

								<!-- Stat grid -->
								<div class={`grid grid-cols-2 gap-3 mb-6 bg-[var(--bg-card)] border ${accent.border} rounded-xl p-4 sm:p-5`}>
									{project.stats.map((stat) => (
										<div>
											<div class="text-[10px] sm:text-xs text-[var(--text-muted)] font-mono uppercase tracking-wider mb-0.5">{stat.label}</div>
											<div class={`text-base sm:text-lg font-bold ${accent.eyebrow} font-mono`}>{stat.value}</div>
										</div>
									))}
								</div>

								{project.url && (
									<a href={project.url} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener noreferrer' : undefined} class={`inline-flex items-center gap-1.5 text-sm font-semibold ${accent.eyebrow} ${accent.hover} transition-colors`}>
										{isExternal ? 'Visit Site' : 'Back to Homepage'}
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
										</svg>
									</a>
								)}
							</div>
						</article>
					);
				})}
			</div>
		</section>

		{caseStudies.length > 0 && (
			<!-- ============================================
			     CASE STUDIES (content collection)
			     ============================================ -->
			<section class="relative py-16 sm:py-20 md:py-24 section-muted border-y border-[var(--stroke)]" aria-label="Case studies">
				<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
					<div class="text-center mb-12">
						<span class="inline-block text-xs font-mono uppercase tracking-[0.2em] text-[var(--accent-cyan)] mb-3">
							Deeper Dives
						</span>
						<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-3">
							Case <span class="text-[var(--accent-cyan)]">Studies</span>
						</h2>
						<p class="text-base sm:text-lg text-[var(--text-body)] max-w-2xl mx-auto">
							The longer stories behind the builds.
						</p>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
						{caseStudies.map((study) => (
							<a href={`/work/${study.slug}`} class="group bg-[var(--bg-card)] border border-[var(--stroke)] rounded-xl p-6 sm:p-7 hover:border-cyan-500/40 hover:-translate-y-1 hover:shadow-[0_0_24px_rgba(34,211,238,0.12)] transition-all duration-300">
								<h3 class="text-lg font-semibold text-[var(--text-header)] mb-2 group-hover:text-[var(--accent-cyan)] transition-colors">
									{study.data.title}
								</h3>
								<p class="text-sm text-[var(--text-body)] leading-relaxed mb-4 line-clamp-3">{study.data.description}</p>
								<div class="flex items-center justify-between pt-4 border-t border-[var(--stroke)]">
									<span class="text-xs text-[var(--text-muted)] font-mono">{study.data.result}</span>
									<span class="text-sm font-medium text-[var(--accent-cyan)] inline-flex items-center gap-1">
										Read <span aria-hidden="true">&rarr;</span>
									</span>
								</div>
							</a>
						))}
					</div>
				</div>
			</section>
		)}

		<!-- ============================================
		     CTA BANNER
		     ============================================ -->
		<section class="relative py-20 sm:py-24 overflow-hidden" aria-label="Start a project">
			<div class="absolute inset-0 -z-10 bg-gradient-to-br from-[var(--bg-card)] via-[var(--bg-page)] to-cyan-950/30"></div>
			<div class="absolute inset-0 -z-10 dot-grid opacity-40"></div>
			<div class="absolute top-0 left-1/4 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl pointer-events-none"></div>
			<div class="absolute bottom-0 right-1/4 w-96 h-96 bg-cyan-400/10 rounded-full blur-3xl pointer-events-none"></div>

			<div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-5 leading-tight">
					Got an idea worth <span class="text-[var(--accent-cyan)] drop-shadow-[0_0_18px_rgba(34,211,238,0.5)]">shipping?</span>
				</h2>
				<p class="text-base sm:text-lg md:text-xl text-[var(--text-body)] mb-10 max-w-xl mx-auto leading-relaxed">
					Tell us what you're working on. We'll tell you if we can help.
				</p>
				<a href="/contact" class="inline-flex items-center justify-center bg-cyan-500 text-slate-950 px-8 py-4 rounded-md font-semibold text-base sm:text-lg hover:bg-cyan-400 transition-all duration-300 shadow-lg shadow-cyan-500/40 hover:shadow-xl hover:shadow-cyan-500/50 hover:-translate-y-0.5 min-h-[52px]">
					Start a Conversation
					<svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
					</svg>
				</a>
			</div>
		</section>

	</main>
</Layout>
</content>
</invoke>