---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Services | Custom Software, Online Stores & Automation | First Layer Digital"
	description="Live dashboards, workflow automation, custom online stores, and fast marketing sites. Built for small businesses that want to grow without hiring a second team."
>
	<main class="relative overflow-hidden" role="main">

		<!-- ============================================
		     HERO
		     ============================================ -->
		<section class="relative pt-12 sm:pt-16 md:pt-24 pb-12 sm:pb-16 px-4 sm:px-6" aria-label="Services hero">
			<!-- Decorative background -->
			<div class="absolute inset-0 -z-10 pointer-events-none">
				<div class="absolute top-0 right-1/4 w-96 h-96 bg-[var(--accent-cyan)]/10 rounded-full blur-3xl"></div>
				<div class="absolute bottom-0 left-1/4 w-72 h-72 bg-[var(--accent-cyan)]/8 rounded-full blur-3xl"></div>
			</div>

			<div class="max-w-4xl mx-auto text-center">
				<div class="inline-flex items-center gap-2 bg-[var(--bg-card)] border border-[var(--stroke)] rounded-full px-4 py-1.5 mb-6 text-xs font-mono uppercase tracking-wider text-[var(--text-muted)]">
					<span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
					What We Do
				</div>

				<h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-6 leading-[1.05]">
					Built for Real Work.<br />
					<span style="color: #3b82f6;">Not Just Demos.</span>
				</h1>

				<p class="text-lg sm:text-xl text-[var(--text-body)] max-w-2xl mx-auto leading-relaxed">
					Dashboards, automations, online stores, and fast websites. Pick one, or pick a few. We build what earns its keep.
				</p>
			</div>
		</section>

		<!-- ============================================
		     4 SERVICE OFFERINGS (alternating layout)
		     ============================================ -->
		<section class="relative py-16 sm:py-20 md:py-24 border-t border-[var(--stroke)]" aria-label="Services">
			<!-- Subtle dot grid background -->
			<div class="absolute inset-0 -z-10 pointer-events-none dot-grid-subtle opacity-40"></div>

			<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16 sm:space-y-20">

				<!-- Service 1: Live Dashboards -->
				<div class="grid md:grid-cols-2 gap-8 sm:gap-12 items-center">
					<div class="order-2 md:order-1">
						<span class="inline-block text-xs font-mono uppercase tracking-[0.2em] text-[var(--accent-cyan)] mb-3">
							01 / Live Dashboards
						</span>
						<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4 leading-tight">
							See Your Numbers. <span class="text-[var(--accent-cyan)]">All of Them.</span>
						</h2>
						<p class="text-base sm:text-lg text-[var(--text-body)] mb-6 leading-relaxed">
							Stop pulling numbers out of five different tabs into a spreadsheet every Monday. We build live dashboards that pull from every platform you use and show you what actually moves the needle.
						</p>
						<ul class="space-y-3 text-[var(--text-body)]">
							<li class="flex items-start gap-3"><span class="text-[var(--accent-cyan)] mt-1 flex-shrink-0">&rarr;</span><span>Sales, traffic, and ad spend in one place</span></li>
							<li class="flex items-start gap-3"><span class="text-[var(--accent-cyan)] mt-1 flex-shrink-0">&rarr;</span><span>Alerts when something needs your attention</span></li>
							<li class="flex items-start gap-3"><span class="text-[var(--accent-cyan)] mt-1 flex-shrink-0">&rarr;</span><span>Weekly reports sent to your inbox, ready to read</span></li>
						</ul>
					</div>
					<div class="order-1 md:order-2 relative">
						<div class="absolute -top-4 -right-4 w-10 h-10 rounded-lg bg-cyan-500/20 rotate-12 float-shape hidden md:block"></div>
						<div class="browser-frame">
							<div class="bg-[var(--bg-card)] p-5 sm:p-6 space-y-4">
								<!-- KPI row -->
								<div class="grid grid-cols-3 gap-3">
									<div class="bg-[var(--bg-muted)] border border-[var(--stroke)] rounded-lg p-3">
										<div class="text-[10px] text-[var(--text-muted)] font-mono uppercase tracking-wider mb-1">Revenue</div>
										<div class="text-lg font-bold text-[var(--text-header)] font-mono">$48,210</div>
										<div class="text-[10px] text-emerald-400 font-mono mt-0.5">&uarr; 12.4%</div>
									</div>
									<div class="bg-[var(--bg-muted)] border border-[var(--stroke)] rounded-lg p-3">
										<div class="text-[10px] text-[var(--text-muted)] font-mono uppercase tracking-wider mb-1">Orders</div>
										<div class="text-lg font-bold text-[var(--text-header)] font-mono">312</div>
										<div class="text-[10px] text-emerald-400 font-mono mt-0.5">&uarr; 8.1%</div>
									</div>
									<div class="bg-[var(--bg-muted)] border border-[var(--stroke)] rounded-lg p-3">
										<div class="text-[10px] text-[var(--text-muted)] font-mono uppercase tracking-wider mb-1">ROAS</div>
										<div class="text-lg font-bold text-[var(--text-header)] font-mono">10.2x</div>
										<div class="text-[10px] text-emerald-400 font-mono mt-0.5">&uarr; 0.4x</div>
									</div>
								</div>

								<!-- Chart card -->
								<div class="bg-[var(--bg-muted)] border border-[var(--stroke)] rounded-lg p-4">
									<div class="flex items-center justify-between mb-3">
										<span class="text-xs text-[var(--text-header)] font-semibold">Weekly Revenue</span>
										<span class="text-[10px] text-[var(--text-muted)] font-mono">Last 7 days</span>
									</div>
									<!-- SVG sparkline / bar chart -->
									<svg viewBox="0 0 300 90" class="w-full h-20" preserveAspectRatio="none" aria-hidden="true">
										<defs>
											<linearGradient id="chartFill" x1="0" y1="0" x2="0" y2="1">
												<stop offset="0%" stop-color="#22d3ee" stop-opacity="0.4" />
												<stop offset="100%" stop-color="#22d3ee" stop-opacity="0" />
											</linearGradient>
										</defs>
										<path d="M0,70 L42,55 L84,60 L126,40 L168,45 L210,25 L252,30 L300,12 L300,90 L0,90 Z" fill="url(#chartFill)" />
										<path d="M0,70 L42,55 L84,60 L126,40 L168,45 L210,25 L252,30 L300,12" fill="none" stroke="#22d3ee" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
										<circle cx="300" cy="12" r="3" fill="#22d3ee" />
									</svg>
								</div>

								<!-- Alert row -->
								<div class="bg-[var(--bg-muted)] border border-emerald-500/30 rounded-lg p-3 flex items-center gap-3">
									<div class="w-8 h-8 rounded-md bg-emerald-500/20 border border-emerald-500/40 flex items-center justify-center flex-shrink-0">
										<svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
									</div>
									<div class="flex-1 min-w-0">
										<div class="text-xs text-[var(--text-header)] font-semibold truncate">Checkout conversion up 14%</div>
										<div class="text-[10px] text-[var(--text-muted)] font-mono">Sent to Slack · 2 min ago</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Service 2: Workflow Automation -->
				<div class="grid md:grid-cols-2 gap-8 sm:gap-12 items-center">
					<div class="relative">
						<div class="absolute -bottom-4 -left-4 w-8 h-8 rounded-full bg-emerald-400/30 float-shape float-shape-slow hidden md:block"></div>
						<div class="bg-[var(--bg-card)] border border-[var(--stroke)] rounded-xl p-8 sm:p-10 relative overflow-hidden">
							<div class="absolute inset-0 dot-grid opacity-20"></div>
							<div class="relative z-10 space-y-4">
								<div class="flex items-center gap-3 p-3 rounded-lg bg-[var(--bg-muted)] border border-[var(--stroke)]">
									<div class="w-8 h-8 rounded-md bg-emerald-500/20 border border-emerald-500/40 flex items-center justify-center flex-shrink-0">
										<svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
									</div>
									<span class="text-sm text-[var(--text-body)] font-mono">Order placed</span>
								</div>
								<div class="pl-4 border-l-2 border-cyan-500/40 ml-4 h-4"></div>
								<div class="flex items-center gap-3 p-3 rounded-lg bg-[var(--bg-muted)] border border-[var(--stroke)]">
									<div class="w-8 h-8 rounded-md bg-cyan-500/20 border border-cyan-500/40 flex items-center justify-center flex-shrink-0">
										<svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
									</div>
									<span class="text-sm text-[var(--text-body)] font-mono">Shipping label printed</span>
								</div>
								<div class="pl-4 border-l-2 border-cyan-500/40 ml-4 h-4"></div>
								<div class="flex items-center gap-3 p-3 rounded-lg bg-[var(--bg-muted)] border border-[var(--stroke)]">
									<div class="w-8 h-8 rounded-md bg-violet-500/20 border border-violet-500/40 flex items-center justify-center flex-shrink-0">
										<svg class="w-4 h-4 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
									</div>
									<span class="text-sm text-[var(--text-body)] font-mono">Customer notified</span>
								</div>
							</div>
						</div>
					</div>
					<div>
						<span class="inline-block text-xs font-mono uppercase tracking-[0.2em] text-[var(--accent-cyan)] mb-3">
							02 / Workflow Automation
						</span>
						<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4 leading-tight">
							Cut the <span class="text-[var(--accent-cyan)]">Busywork.</span>
						</h2>
						<p class="text-base sm:text-lg text-[var(--text-body)] mb-6 leading-relaxed">
							If you're doing it by hand and it follows a pattern, we can automate it. Get hours back every week so you can focus on what actually grows the business.
						</p>
						<ul class="space-y-3 text-[var(--text-body)]">
							<li class="flex items-start gap-3"><span class="text-[var(--accent-cyan)] mt-1 flex-shrink-0">&rarr;</span><span>Connect tools that don't talk to each other</span></li>
							<li class="flex items-start gap-3"><span class="text-[var(--accent-cyan)] mt-1 flex-shrink-0">&rarr;</span><span>Auto-send reports, invoices, and notifications</span></li>
							<li class="flex items-start gap-3"><span class="text-[var(--accent-cyan)] mt-1 flex-shrink-0">&rarr;</span><span>Sync inventory, orders, and shipping data</span></li>
						</ul>
					</div>
				</div>

				<!-- Service 3: Online Stores -->
				<div class="grid md:grid-cols-2 gap-8 sm:gap-12 items-center">
					<div class="order-2 md:order-1">
						<span class="inline-block text-xs font-mono uppercase tracking-[0.2em] text-[var(--accent-cyan)] mb-3">
							03 / Online Stores
						</span>
						<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4 leading-tight">
							Stores That <span class="text-[var(--accent-cyan)]">Actually Sell.</span>
						</h2>
						<p class="text-base sm:text-lg text-[var(--text-body)] mb-6 leading-relaxed">
							Not just a pretty storefront. A store wired into the rest of your business, with a wholesale portal, ad tracking that actually works, and shipping that runs itself.
						</p>
						<ul class="space-y-3 text-[var(--text-body)]">
							<li class="flex items-start gap-3"><span class="text-[var(--accent-cyan)] mt-1 flex-shrink-0">&rarr;</span><span>Custom wholesale portals with quick-order pages</span></li>
							<li class="flex items-start gap-3"><span class="text-[var(--accent-cyan)] mt-1 flex-shrink-0">&rarr;</span><span>Accurate ad conversion tracking, no guessing</span></li>
							<li class="flex items-start gap-3"><span class="text-[var(--accent-cyan)] mt-1 flex-shrink-0">&rarr;</span><span>Shipping, inventory, and tax hooked straight in</span></li>
						</ul>
					</div>
					<div class="order-1 md:order-2 relative">
						<div class="absolute top-1/2 -right-6 w-3 h-3 rounded-full bg-emerald-400/50 float-shape hidden md:block"></div>
						<div class="browser-frame">
							<img src="/images/p1-packaging-showcase.png" alt="Custom online store with wholesale portal" loading="lazy" width="1280" height="800" />
						</div>
					</div>
				</div>

				<!-- Service 4: Fast Websites -->
				<div class="grid md:grid-cols-2 gap-8 sm:gap-12 items-center">
					<div class="relative">
						<div class="absolute -top-4 -right-4 w-12 h-12 rounded-lg bg-violet-500/20 rotate-12 float-shape hidden md:block"></div>
						<div class="bg-[var(--bg-card)] border border-[var(--stroke)] rounded-xl p-8 sm:p-10 relative overflow-hidden">
							<div class="absolute inset-0 dot-grid opacity-20"></div>
							<div class="relative z-10">
								<div class="grid grid-cols-2 gap-4 mb-6">
									<div class="bg-[var(--bg-muted)] border border-[var(--stroke)] rounded-lg p-4 text-center">
										<div class="text-xs text-[var(--text-muted)] font-mono mb-1 uppercase tracking-wider">Lighthouse</div>
										<div class="text-3xl font-bold text-emerald-400 font-mono">98</div>
									</div>
									<div class="bg-[var(--bg-muted)] border border-[var(--stroke)] rounded-lg p-4 text-center">
										<div class="text-xs text-[var(--text-muted)] font-mono mb-1 uppercase tracking-wider">Load Time</div>
										<div class="text-3xl font-bold text-cyan-400 font-mono">&lt;0.5s</div>
									</div>
								</div>
								<div class="bg-[var(--bg-muted)] border border-[var(--stroke)] rounded-lg p-4">
									<div class="flex items-center justify-between mb-2">
										<span class="text-xs text-[var(--text-muted)] font-mono uppercase tracking-wider">Core Web Vitals</span>
										<span class="text-xs font-semibold text-emerald-400 font-mono">All Green</span>
									</div>
									<div class="flex gap-1.5">
										<div class="flex-1 h-2 rounded-full bg-emerald-500"></div>
										<div class="flex-1 h-2 rounded-full bg-emerald-500"></div>
										<div class="flex-1 h-2 rounded-full bg-emerald-500"></div>
									</div>
								</div>
							</div>
						</div>
					</div>
					<div>
						<span class="inline-block text-xs font-mono uppercase tracking-[0.2em] text-[var(--accent-cyan)] mb-3">
							04 / Fast Websites
						</span>
						<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4 leading-tight">
							Websites That <span class="text-[var(--accent-cyan)]">Load & Rank.</span>
						</h2>
						<p class="text-base sm:text-lg text-[var(--text-body)] mb-6 leading-relaxed">
							Pages that load before your visitor blinks. Built to rank on Google and convert real customers, not just win design awards.
						</p>
						<ul class="space-y-3 text-[var(--text-body)]">
							<li class="flex items-start gap-3"><span class="text-[var(--accent-cyan)] mt-1 flex-shrink-0">&rarr;</span><span>Under a second load time on real devices</span></li>
							<li class="flex items-start gap-3"><span class="text-[var(--accent-cyan)] mt-1 flex-shrink-0">&rarr;</span><span>Built right for Google from day one</span></li>
							<li class="flex items-start gap-3"><span class="text-[var(--accent-cyan)] mt-1 flex-shrink-0">&rarr;</span><span>Easy to update, cheap to host, nothing breaking in the background</span></li>
						</ul>
					</div>
				</div>

			</div>
		</section>

		<!-- ============================================
		     HOW WE PRICE
		     ============================================ -->
		<section class="relative py-16 sm:py-20 md:py-24 section-muted border-y border-[var(--stroke)]" aria-label="How we price">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="text-center mb-12 sm:mb-16">
					<span class="inline-block text-xs font-mono uppercase tracking-[0.2em] text-[var(--accent-cyan)] mb-3">
						No Surprise Invoices
					</span>
					<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-3">
						How We <span class="text-[var(--accent-cyan)]">Price</span>
					</h2>
					<p class="text-base sm:text-lg text-[var(--text-body)] max-w-2xl mx-auto">
						Flexible pricing that matches the shape of the work.
					</p>
				</div>

				<div class="grid md:grid-cols-3 gap-6">
					<!-- Consultation -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] rounded-xl p-6 sm:p-8 hover:border-cyan-500/40 transition-all duration-300">
						<div class="w-12 h-12 rounded-lg bg-[var(--accent-subtle)] border border-cyan-500/20 flex items-center justify-center mb-5">
							<svg class="w-6 h-6 text-[var(--accent-cyan)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
							</svg>
						</div>
						<h3 class="text-lg sm:text-xl font-semibold text-[var(--text-header)] mb-3">Consultation</h3>
						<p class="text-[var(--text-body)] leading-relaxed text-sm sm:text-base mb-4">
							We sit down, you tell us what's broken or what you're trying to figure out. We come back with a plan and a number.
						</p>
						<div class="bg-[var(--bg-muted)] rounded-md p-3 border border-[var(--stroke)]">
							<p class="text-xs sm:text-sm text-[var(--text-body)]">
								<strong class="text-[var(--text-header)]">Best for:</strong> Scoping a project, figuring out where to start.
							</p>
						</div>
					</div>

					<!-- Fixed-Price -->
					<div class="bg-[var(--bg-card)] border-2 border-[var(--accent-cyan)] rounded-xl p-6 sm:p-8 relative shadow-[0_0_40px_rgba(34,211,238,0.1)]">
						<span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-cyan-500 text-slate-950 text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wider">
							Most Common
						</span>
						<div class="w-12 h-12 rounded-lg bg-[var(--accent-subtle)] border border-cyan-500/40 flex items-center justify-center mb-5">
							<svg class="w-6 h-6 text-[var(--accent-cyan)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
							</svg>
						</div>
						<h3 class="text-lg sm:text-xl font-semibold text-[var(--text-header)] mb-3">Fixed-Price Build</h3>
						<p class="text-[var(--text-body)] leading-relaxed text-sm sm:text-base mb-4">
							Clear scope, clear timeline, one number on the invoice. No surprise charges when we hit a snag.
						</p>
						<div class="bg-[var(--bg-muted)] rounded-md p-3 border border-[var(--stroke)]">
							<p class="text-xs sm:text-sm text-[var(--text-body)]">
								<strong class="text-[var(--text-header)]">Best for:</strong> Launching a product, rebuilding a site, shipping a defined feature.
							</p>
						</div>
					</div>

					<!-- Ongoing -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] rounded-xl p-6 sm:p-8 hover:border-cyan-500/40 transition-all duration-300">
						<div class="w-12 h-12 rounded-lg bg-[var(--accent-subtle)] border border-cyan-500/20 flex items-center justify-center mb-5">
							<svg class="w-6 h-6 text-[var(--accent-cyan)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
							</svg>
						</div>
						<h3 class="text-lg sm:text-xl font-semibold text-[var(--text-header)] mb-3">Ongoing Support</h3>
						<p class="text-[var(--text-body)] leading-relaxed text-sm sm:text-base mb-4">
							After launch we stick around. Monthly retainers for updates, improvements, and keeping everything running without a hitch.
						</p>
						<div class="bg-[var(--bg-muted)] rounded-md p-3 border border-[var(--stroke)]">
							<p class="text-xs sm:text-sm text-[var(--text-body)]">
								<strong class="text-[var(--text-header)]">Best for:</strong> Keeping things healthy, rolling out improvements, staying ahead.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ============================================
		     60-DAY SUPPORT CALLOUT
		     ============================================ -->
		<section class="relative py-16 sm:py-20" aria-label="Post-launch support">
			<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="relative bg-[var(--bg-card)] border border-[var(--stroke)] rounded-2xl p-8 sm:p-12 overflow-hidden">
					<div class="absolute inset-0 dot-grid opacity-30 pointer-events-none"></div>
					<div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-cyan-500 via-cyan-400 to-cyan-500"></div>
					<div class="absolute top-6 right-6 w-3 h-3 rounded-full bg-cyan-400/40 float-shape hidden sm:block"></div>

					<div class="relative z-10 text-center">
						<span class="inline-block text-xs font-mono uppercase tracking-[0.2em] text-[var(--accent-cyan)] mb-3">
							Included with Every Build
						</span>
