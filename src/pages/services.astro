---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services | FirstLayer Digital" description="Operational infrastructure, internal tools, data dashboards (Streamlit), and private cloud solutions (Proxmox, Nextcloud). Custom business infrastructure and web development services.">
	<main role="main">

		<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
			<!-- Hero -->
			<div class="text-center mb-16 sm:mb-20">
				<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 leading-tight">
					Professional <span class="text-[var(--accent-cyan)] drop-shadow-[0_0_12px_rgba(34,211,238,0.3)]">Services</span>
				</h1>
				<p class="text-lg sm:text-xl text-[var(--text-body)] max-w-2xl mx-auto leading-relaxed">
					Engineering-driven solutions that deliver measurable results. From concept to deployment, we build with precision and purpose.
				</p>
			</div>

			<!-- Core Services -->
			<section class="mb-16 sm:mb-20">
				<h2 class="text-2xl sm:text-3xl font-bold mb-8 text-center">Core Services</h2>

				<div class="grid md:grid-cols-2 gap-6">
					<!-- Website Design -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] p-6 sm:p-8 rounded-lg">
						<h3 class="text-lg sm:text-xl font-semibold text-[var(--text-header)] mb-3">Website Design & Development</h3>
						<p class="text-sm sm:text-base text-[var(--text-body)] leading-relaxed mb-4">
							Custom-built websites engineered for performance, security, and scalability. We leverage modern frameworks and best practices to deliver sites that load fast, rank well, and convert.
						</p>
						<ul class="text-sm sm:text-base text-[var(--text-body)] space-y-2">
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Responsive, mobile-first design</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>SEO-optimized architecture</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Performance optimization (90+ Lighthouse)</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Security hardening and best practices</li>
						</ul>
					</div>

					<!-- Custom Software -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] p-6 sm:p-8 rounded-lg">
						<h3 class="text-lg sm:text-xl font-semibold text-[var(--text-header)] mb-3">Custom Software Development</h3>
						<p class="text-sm sm:text-base text-[var(--text-body)] leading-relaxed mb-4">
							Tailored software solutions built to solve specific business challenges. From internal tools to customer-facing applications, we develop robust, maintainable code that scales.
						</p>
						<ul class="text-sm sm:text-base text-[var(--text-body)] space-y-2">
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Full-stack development</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>API design and integration</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Database architecture</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>DevOps and deployment automation</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Internal tools and operational infrastructure</li>
						</ul>
					</div>

					<!-- E-commerce -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] p-6 sm:p-8 rounded-lg">
						<h3 class="text-lg sm:text-xl font-semibold text-[var(--text-header)] mb-3">E-commerce Optimization</h3>
						<p class="text-sm sm:text-base text-[var(--text-body)] leading-relaxed mb-4">
							Maximize your online store's performance and profitability. We optimize checkout flows, improve conversion rates, and integrate payment systems that reduce friction.
						</p>
						<ul class="text-sm sm:text-base text-[var(--text-body)] space-y-2">
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Platform setup and configuration</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Inventory management systems</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Payment gateway integration</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Conversion rate optimization</li>
						</ul>
					</div>

					<!-- SEO -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] p-6 sm:p-8 rounded-lg">
						<h3 class="text-lg sm:text-xl font-semibold text-[var(--text-header)] mb-3">Search Engine Optimization</h3>
						<p class="text-sm sm:text-base text-[var(--text-body)] leading-relaxed mb-4">
							Technical SEO implementation that improves your search rankings and organic visibility. We optimize site structure, metadata, and performance to help you rank higher.
						</p>
						<ul class="text-sm sm:text-base text-[var(--text-body)] space-y-2">
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>On-page optimization</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Technical SEO audits</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Schema markup implementation</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Core Web Vitals optimization</li>
						</ul>
					</div>
				</div>
			</section>

			<!-- Operational Infrastructure -->
			<section id="operational-infrastructure" class="mb-16 sm:mb-20">
				<div class="text-center mb-8">
					<h2 class="text-2xl sm:text-3xl font-bold mb-3">Operational Infrastructure & Internal Tools</h2>
					<p class="text-base sm:text-lg text-[var(--text-body)] max-w-2xl mx-auto leading-relaxed">
						Specialized solutions for custom business infrastructure, data visualization, and private cloud deployments.
					</p>
				</div>

				<div class="grid md:grid-cols-2 gap-6">
					<!-- Data Dashboards -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] p-6 sm:p-8 rounded-lg">
						<h3 class="text-lg sm:text-xl font-semibold text-[var(--text-header)] mb-3">Data Dashboards & Streamlit</h3>
						<p class="text-sm sm:text-base text-[var(--text-body)] leading-relaxed mb-4">
							Custom data dashboards and interactive analytics tools built with Streamlit. Transform your business data into actionable insights with intuitive visualizations.
						</p>
						<ul class="text-sm sm:text-base text-[var(--text-body)] space-y-2">
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Streamlit dashboard development</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Custom data visualization pipelines</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Real-time analytics and reporting</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Data integration and ETL processes</li>
						</ul>
					</div>

					<!-- Private Cloud -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] p-6 sm:p-8 rounded-lg">
						<h3 class="text-lg sm:text-xl font-semibold text-[var(--text-header)] mb-3">Private Cloud & Infrastructure</h3>
						<p class="text-sm sm:text-base text-[var(--text-body)] leading-relaxed mb-4">
							Private cloud infrastructure using Proxmox and Nextcloud. Secure, self-hosted solutions for data sovereignty and complete control over your business infrastructure.
						</p>
						<ul class="text-sm sm:text-base text-[var(--text-body)] space-y-2">
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Proxmox virtualization and containerization</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Nextcloud private cloud deployment</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Infrastructure automation and orchestration</li>
							<li class="flex items-start gap-2"><span class="text-[var(--accent)] mt-1">&bull;</span>Security hardening and backup strategies</li>
						</ul>
					</div>
				</div>
			</section>

			<!-- Pricing Model -->
			<section class="mb-16 sm:mb-20">
				<div class="text-center mb-8">
					<h2 class="text-2xl sm:text-3xl font-bold mb-3">Hybrid Pricing Model</h2>
					<p class="text-base sm:text-lg text-[var(--text-body)] max-w-2xl mx-auto leading-relaxed">
						Flexible pricing structures designed to align with your project needs and budget.
					</p>
				</div>

				<div class="grid md:grid-cols-3 gap-6">
					<!-- Consultation -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] rounded-lg p-6 sm:p-8">
						<h3 class="text-lg sm:text-xl font-semibold text-[var(--text-header)] mb-3">Consultation Fees</h3>
						<p class="text-sm sm:text-base text-[var(--text-body)] leading-relaxed mb-4">
							Strategic planning and technical consultation to help define your project scope, requirements, and optimal technology stack.
						</p>
						<div class="bg-[var(--bg-muted)] rounded-md p-3 border border-[var(--stroke)]">
							<p class="text-xs sm:text-sm text-[var(--text-body)]">
								<strong class="text-[var(--text-header)]">Ideal for:</strong> Project scoping, technology selection, architecture planning.
							</p>
						</div>
					</div>

					<!-- Fixed-Price -->
					<div class="bg-[var(--bg-card)] border-2 border-[var(--accent)] rounded-lg p-6 sm:p-8 relative">
						<h3 class="text-lg sm:text-xl font-semibold text-[var(--text-header)] mb-3">Fixed-Price MVPs</h3>
						<p class="text-sm sm:text-base text-[var(--text-body)] leading-relaxed mb-4">
							Predictable pricing for well-defined projects. Complete, production-ready MVPs with clear deliverables, timelines, and budgets.
						</p>
						<div class="bg-[var(--bg-muted)] rounded-md p-3 border border-[var(--stroke)]">
							<p class="text-xs sm:text-sm text-[var(--text-body)]">
								<strong class="text-[var(--text-header)]">Ideal for:</strong> New product launches, feature-complete websites, defined scope.
							</p>
						</div>
					</div>

					<!-- Maintenance -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] rounded-lg p-6 sm:p-8">
						<h3 class="text-lg sm:text-xl font-semibold text-[var(--text-header)] mb-3">Operational Maintenance</h3>
						<p class="text-sm sm:text-base text-[var(--text-body)] leading-relaxed mb-4">
							Ongoing Proxmox host health monitoring, security patching, cloudflared tunnel stability, and automated data integrity backups.
						</p>
						<div class="bg-[var(--bg-muted)] rounded-md p-3 border border-[var(--stroke)]">
							<p class="text-xs sm:text-sm text-[var(--text-body)]">
								<strong class="text-[var(--text-header)]">Ideal for:</strong> Established infrastructure requiring ongoing technical oversight.
							</p>
						</div>
					</div>
				</div>
			</section>

			<!-- 60-Day Support -->
			<section class="mb-16 sm:mb-20">
				<div class="bg-[var(--accent)] rounded-lg p-8 sm:p-12 text-center">
					<h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">60-Day Post-Launch Support</h2>
					<p class="text-cyan-50 mb-8 max-w-2xl mx-auto text-base sm:text-lg leading-relaxed">
						Every project includes a comprehensive 60-day post-launch support period at no additional cost.
					</p>
					<div class="grid sm:grid-cols-3 gap-4 max-w-3xl mx-auto text-left">
						<div class="bg-white/10 rounded-md p-4">
							<h3 class="text-white font-semibold text-sm mb-1">Bug Fixes</h3>
							<p class="text-cyan-50/80 text-xs sm:text-sm">Rapid resolution of any issues discovered after launch</p>
						</div>
						<div class="bg-white/10 rounded-md p-4">
							<h3 class="text-white font-semibold text-sm mb-1">Technical Support</h3>
							<p class="text-cyan-50/80 text-xs sm:text-sm">Direct access to our team for questions and guidance</p>
						</div>
						<div class="bg-white/10 rounded-md p-4">
							<h3 class="text-white font-semibold text-sm mb-1">Performance Monitoring</h3>
							<p class="text-cyan-50/80 text-xs sm:text-sm">Ongoing monitoring to ensure optimal performance</p>
						</div>
					</div>
				</div>
			</section>

			<!-- CTA -->
			<section class="text-center">
				<h2 class="text-2xl sm:text-3xl font-bold mb-4">Ready to Get Started?</h2>
				<p class="text-base sm:text-lg text-[var(--text-body)] mb-8 max-w-2xl mx-auto leading-relaxed">
					Let's discuss your project and determine the best pricing model for your needs.
				</p>
				<a href="/contact" class="inline-block bg-[var(--accent)] text-white px-6 py-3 rounded-md font-medium text-base sm:text-lg hover:bg-[var(--accent-hover)] transition-colors duration-200 min-h-[48px]">
					Schedule a Consultation
				</a>
			</section>
		</div>
	</main>
</Layout>
