---
import Layout from '../layouts/Layout.astro';

export const prerender = true;
---
<Layout>
	<main>
		<div class="max-w-xl mx-auto px-4 sm:px-6 py-24 sm:py-32 text-center">
			<div class="w-16 h-16 bg-emerald-100 dark:bg-emerald-900/30 rounded-full flex items-center justify-center mx-auto mb-6">
				<svg class="w-8 h-8 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
				</svg>
			</div>

			<h1 class="text-3xl sm:text-4xl font-bold mb-4">
				Message <span class="text-emerald-600 dark:text-emerald-400">Sent!</span>
			</h1>
			<p class="text-lg text-[var(--text-body)] mb-8 leading-relaxed">
				Thanks for reaching out. We'll be in touch shortly.
			</p>

			<a href="/" class="inline-flex items-center gap-2 bg-[var(--accent)] text-white px-6 py-3 rounded-md font-medium hover:bg-[var(--accent-hover)] transition-colors duration-200 min-h-[48px]">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
				</svg>
				Return Home
			</a>
		</div>
	</main>

	<!-- Google Ads conversion -->
	<script is:inline>
		(function() {
			if (typeof window === 'undefined' || typeof sessionStorage === 'undefined') return;
			var path = (window.location.pathname || '').replace(/\/$/, '') || '/';
			if (path !== '/success') return;
			var firedKey = 'fl_ads_conversion_fired';
			if (sessionStorage.getItem(firedKey)) return;
			sessionStorage.setItem(firedKey, '1');

			function fire() {
				window.dataLayer = window.dataLayer || [];
				if (typeof gtag === 'function') {
					gtag('event', 'conversion', { 'send_to': 'AW-17896889359' });
				} else {
					window.dataLayer.push(['event', 'conversion', { 'send_to': 'AW-17896889359' }]);
				}
			}
			setTimeout(fire, 1500);
		})();
	</script>
</Layout>
