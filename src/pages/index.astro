---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
---

<Layout
	title="Bespoke Web Design & SEO | High-Performance Websites | Pasadena, Maryland | First Layer Digital"
	description="Pasadena, Maryland computer systems design specializing in bespoke web design, technical SEO, e-commerce optimization, and high-performance web development. Optimized for search & speed."
>
	<main role="main">

		<!-- Hero Section -->
		<section class="max-w-3xl mx-auto pt-16 sm:pt-24 md:pt-32 pb-16 sm:pb-20 text-center px-4 sm:px-6" aria-label="Hero Section">
			<h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-6 leading-[1.1]">
				Not Just Pretty.<br />
				<span class="text-[var(--accent-cyan)] drop-shadow-[0_0_12px_rgba(34,211,238,0.3)]">Built to Run.</span>
			</h1>

			<p class="text-lg sm:text-xl text-[var(--text-body)] mb-10 leading-relaxed max-w-2xl mx-auto">
				We bridge the gap between stunning digital storefronts and the automated systems that run them. From SEO-optimized websites to custom market intelligence dashboards, we build what your business actually needs.
			</p>

			<div class="flex flex-col sm:flex-row justify-center items-stretch sm:items-center gap-3 sm:gap-4">
				<a href="/contact" class="bg-[var(--accent)] text-white px-6 py-3 rounded-md font-medium text-base sm:text-lg hover:bg-[var(--accent-hover)] transition-colors duration-200 min-h-[48px] flex items-center justify-center">
					Get Started
				</a>
				<a href="/work" class="bg-[var(--bg-page)] text-[var(--text-header)] border border-[var(--stroke)] px-6 py-3 rounded-md font-medium text-base sm:text-lg hover:bg-[var(--bg-muted)] transition-colors duration-200 min-h-[48px] flex items-center justify-center">
					See Our Work
				</a>
			</div>
		</section>

		<!-- Dual-Focus Value Proposition -->
		<section class="border-t border-[var(--stroke)] py-16 sm:py-20">
			<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="text-center mb-12">
					<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-3">
						Two Layers. <span class="text-[var(--accent-cyan)] drop-shadow-[0_0_12px_rgba(34,211,238,0.3)]">One Foundation.</span>
					</h2>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8">
					<!-- Pillar 1 -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] rounded-lg p-6 sm:p-8">
						<div class="w-10 h-10 bg-[var(--accent-subtle)] rounded-md flex items-center justify-center text-[var(--accent)] mb-5">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
							</svg>
						</div>
						<h3 class="text-lg sm:text-xl font-semibold text-[var(--text-header)] mb-2">The Front Layer</h3>
						<p class="text-[var(--text-body)] leading-relaxed">
							High-performance websites and e-commerce platforms designed to dominate search rankings and captivate creative audiences.
						</p>
					</div>

					<!-- Pillar 2 -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] rounded-lg p-6 sm:p-8">
						<div class="w-10 h-10 bg-[var(--accent-subtle)] rounded-md flex items-center justify-center text-[var(--accent)] mb-5">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
							</svg>
						</div>
						<h3 class="text-lg sm:text-xl font-semibold text-[var(--text-header)] mb-2">The Operational Layer</h3>
						<p class="text-[var(--text-body)] leading-relaxed">
							Custom Node.js scrapers, Streamlit visualizations, and Proxmox containerization that reclaim 15+ hours of executive labor every week.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Efficiency Section -->
		<section class="bg-[var(--bg-muted)] py-16 sm:py-20">
			<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4">
					Turn Manual Work Into Automated Intelligence.
				</h2>
				<p class="text-base sm:text-lg text-[var(--text-body)] leading-relaxed">
					In operational infrastructure, manual tracking is a failure of scale. We transform manual processes into automated intelligence systems, allowing you to focus on strategic decision-making while your systems eliminate margin bleed.
				</p>
			</div>
		</section>

		<!-- Featured Work -->
		<section class="py-16 sm:py-20" aria-label="Featured Work">
			<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="text-center mb-12">
					<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-3">Featured Work</h2>
					<p class="text-base sm:text-lg text-[var(--text-body)] max-w-2xl mx-auto">
						Real projects showcasing our full-stack approach: from stunning front-layer websites to powerful back-layer systems.
					</p>
				</div>

				<div class="grid md:grid-cols-3 gap-6">
					<!-- Case Study 1 -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] rounded-lg overflow-hidden hover:border-[var(--accent)]/40 transition-colors duration-200">
						<div class="h-2 bg-[var(--accent)]"></div>
						<div class="p-6">
							<span class="text-xs font-mono text-[var(--accent)] uppercase tracking-wide">Operational Infrastructure</span>
							<h3 class="text-lg font-semibold text-[var(--text-header)] mt-2 mb-3">VantageDash: Automated Market Intelligence</h3>
							<p class="text-sm text-[var(--text-body)] mb-4 leading-relaxed">
								Custom Node.js scrapers and Streamlit visualizations that reclaim 15+ hours of executive labor weekly.
							</p>

							<div class="text-xs font-mono text-[var(--text-muted)] mb-4 pb-4 border-b border-[var(--stroke)]">
								Astro &middot; Tailwind &middot; Netlify
							</div>

							<div class="space-y-2 mb-5 text-sm">
								<div class="flex justify-between">
									<span class="text-[var(--text-muted)]">Lighthouse</span>
									<span class="font-medium text-[var(--text-header)]">98/100</span>
								</div>
								<div class="flex justify-between">
									<span class="text-[var(--text-muted)]">Result</span>
									<span class="font-medium text-[var(--accent)]">40% Faster Load</span>
								</div>
							</div>
							<a href="/work/vantagedash" class="text-sm font-medium text-[var(--accent)] hover:text-[var(--accent-hover)] transition-colors inline-flex items-center gap-1">
								View Case Study <span>&rarr;</span>
							</a>
						</div>
					</div>

					<!-- Case Study 2 -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] rounded-lg overflow-hidden hover:border-[var(--accent)]/40 transition-colors duration-200">
						<div class="h-2 bg-emerald-500"></div>
						<div class="p-6">
							<span class="text-xs font-mono text-emerald-600 dark:text-emerald-400 uppercase tracking-wide">Web Design</span>
							<h3 class="text-lg font-semibold text-[var(--text-header)] mt-2 mb-3">High-Performance Agency Website</h3>
							<p class="text-sm text-[var(--text-body)] mb-4 leading-relaxed">
								SEO-optimized agency website with 98 Lighthouse score and sub-0.5s load times.
							</p>

							<div class="text-xs font-mono text-[var(--text-muted)] mb-4 pb-4 border-b border-[var(--stroke)]">
								Shopify &middot; Node.js &middot; Stripe
							</div>

							<div class="space-y-2 mb-5 text-sm">
								<div class="flex justify-between">
									<span class="text-[var(--text-muted)]">Lighthouse</span>
									<span class="font-medium text-[var(--text-header)]">92/100</span>
								</div>
								<div class="flex justify-between">
									<span class="text-[var(--text-muted)]">Result</span>
									<span class="font-medium text-emerald-600 dark:text-emerald-400">40% Checkout Improvement</span>
								</div>
							</div>
							<a href="/work" class="text-sm font-medium text-[var(--accent)] hover:text-[var(--accent-hover)] transition-colors inline-flex items-center gap-1">
								View Case Study <span>&rarr;</span>
							</a>
						</div>
					</div>

					<!-- Case Study 3 -->
					<div class="bg-[var(--bg-card)] border border-[var(--stroke)] rounded-lg overflow-hidden hover:border-[var(--accent)]/40 transition-colors duration-200">
						<div class="h-2 bg-violet-500"></div>
						<div class="p-6">
							<span class="text-xs font-mono text-violet-600 dark:text-violet-400 uppercase tracking-wide">Infrastructure Engineering</span>
							<h3 class="text-lg font-semibold text-[var(--text-header)] mt-2 mb-3">Proactive Resilience: SSD Health Monitoring</h3>
							<p class="text-sm text-[var(--text-body)] mb-4 leading-relaxed">
								Automated hardware health monitoring that triggers swaps before the 24-hour failure window.
							</p>

							<div class="text-xs font-mono text-[var(--text-muted)] mb-4 pb-4 border-b border-[var(--stroke)]">
								React &middot; Express &middot; PostgreSQL
							</div>

							<div class="space-y-2 mb-5 text-sm">
								<div class="flex justify-between">
									<span class="text-[var(--text-muted)]">Lighthouse</span>
									<span class="font-medium text-[var(--text-header)]">95/100</span>
								</div>
								<div class="flex justify-between">
									<span class="text-[var(--text-muted)]">Result</span>
									<span class="font-medium text-violet-600 dark:text-violet-400">50% Faster API Response</span>
								</div>
							</div>
							<a href="/work" class="text-sm font-medium text-[var(--accent)] hover:text-[var(--accent-hover)] transition-colors inline-flex items-center gap-1">
								View Case Study <span>&rarr;</span>
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="border-t border-[var(--stroke)] py-16 sm:py-20">
			<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4">Ready to Optimize Your Digital Presence?</h2>
				<p class="text-base sm:text-lg text-[var(--text-body)] mb-8 max-w-2xl mx-auto leading-relaxed">
					As a Pasadena, Maryland computer systems design practice, we specialize in high-performance web development and e-commerce optimization. Let's discuss how we can help.
				</p>
				<a href="/contact" class="inline-block bg-[var(--accent)] text-white px-6 py-3 rounded-md font-medium text-base sm:text-lg hover:bg-[var(--accent-hover)] transition-colors duration-200 min-h-[48px]">
					Start a Conversation
				</a>
			</div>
		</section>
	</main>
</Layout>
